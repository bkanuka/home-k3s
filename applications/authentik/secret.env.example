# SAMPLE — copy to the server at /mnt/main/config/authentik/authentik.env and
# fill in real values. NEVER commit the real file (it is gitignored). install.sh
# turns this into the `authentik-secrets` Secret in the authentik namespace via
# `kubectl create secret generic authentik-secrets --from-env-file=...`.
#
# Generate the two random values with:
#   AUTHENTIK_SECRET_KEY:            openssl rand -base64 60 | tr -d '\n'
#   AUTHENTIK_POSTGRESQL__PASSWORD:  openssl rand -base64 36 | tr -d '\n'
#   AUTHENTIK_BOOTSTRAP_PASSWORD:    openssl rand -base64 24 | tr -d '\n'  (initial akadmin password)

# Session/signing key for Authentik (keep stable; rotating logs everyone out).
AUTHENTIK_SECRET_KEY=REPLACE_WITH_RANDOM_60_CHARS

# Password for the bundled PostgreSQL (must match what postgres is created with;
# install.sh seeds both from this one file).
AUTHENTIK_POSTGRESQL__PASSWORD=REPLACE_WITH_RANDOM_DB_PASSWORD

# Initial admin (akadmin) password, used on first boot to bootstrap the admin.
AUTHENTIK_BOOTSTRAP_PASSWORD=REPLACE_WITH_RANDOM_ADMIN_PASSWORD

# Google OAuth client (from Google Cloud Console). The blueprint reads these via
# !Env. Authorized redirect URI on the Google client MUST be exactly:
#   https://authentik.home.bkanuka.com/source/oauth/callback/google/
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
