# SAMPLE — copy to the server at /mnt/main/config/pia/pia.env and fill in your
# PIA credentials. NEVER commit the real file (it is gitignored). install.sh turns
# it into the `pia-credentials` Secret in the qbittorrent namespace via
# `kubectl create secret generic pia-credentials --from-env-file=...`.
PIA_USERNAME=REPLACE_WITH_PIA_USERNAME
PIA_PASSWORD=REPLACE_WITH_PIA_PASSWORD
